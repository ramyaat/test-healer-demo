<% content_for :title, @post.title %>

<div class="page-header">
  <h1><span data-testid="post-title"><%= @post.title %></span></h1>
  <span class="badge <%= @post.published? ? 'badge--published' : 'badge--draft' %>" data-testid="post-status">
    <%= @post.published? ? "Published" : "Draft" %>
  </span>
</div>

<div class="post-detail">
  <div class="post-detail__body" data-testid="post-body"><%= @post.body %></div>
</div>

<div data-testid="post-actions" style="display: flex; gap: .75rem; align-items: center;">
  <%= link_to "Edit", edit_post_path(@post), class: "btn btn--secondary", data: { testid: "edit-post-link" } %>
  <%= link_to "← All Posts", posts_path, class: "btn btn--secondary", data: { testid: "back-to-posts" } %>
  <%= button_to "Delete", @post,
        method: :delete,
        class: "btn btn--danger",
        form_class: "btn-inline-form",
        data: { testid: "delete-post-button", turbo_confirm: "Delete this post?" } %>
</div>
